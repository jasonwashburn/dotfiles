{
  "$schema": "https://opencode.ai/config.json",
  "permission": {
    "bash": {
      "*": "ask",
      "git status*": "allow",
      "git diff*": "allow",
      "git log*": "allow",
      "git branch*": "allow",
      "grep *": "allow",
      "cat *": "allow",
      "ls *": "allow",
      "echo *": "allow",
      "rm *": "deny",
      "rm -rf *": "deny"
    },
    "edit": "ask",
    "webfetch": "ask",
    "websearch": "ask",
    "codesearch": "ask",
    "task": "ask",
    "mcp_*": "ask",

    "read": {
      "*": "allow",
      "*.env": "deny",
      "*.env.*": "deny",
      "*.env.example": "allow"
    },
    "grep": "allow",
    "glob": "allow",
    "list": "allow",
    "lsp": "allow",
    "skill": "allow",
    "question": "allow",
    "todoread": "allow",
    "todowrite": "allow",

    "external_directory": "ask",
    "doom_loop": "ask"
  }
}
