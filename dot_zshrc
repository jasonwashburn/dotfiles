export FZF_CTRL_T_OPTS="
  --preview 'bat --color=always --style=numbers --line-range=:500 {}'
  --preview-window=right:60%:wrap
  --bind 'ctrl-/:change-preview-window(hidden|)'
"

# Alt-C: cd picker with lsd tree preview
